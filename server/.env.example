# Shubra Jewels API
PORT=4200
HOST=0.0.0.0
NODE_ENV=development

# MongoDB Atlas connection string (must include the `shubra` database name)
MONGODB_URI=mongodb+srv://user:pass@cluster/shubra?retryWrites=true&w=majority

# Auth
JWT_SECRET=change_me
JWT_EXPIRES_IN=30d

# Seed admin (used only by `npm run seed`)
ADMIN_EMAIL=admin@shubrajewels.in
ADMIN_PASSWORD=change_me

# Public base URL for absolute media links (optional)
PUBLIC_URL=
