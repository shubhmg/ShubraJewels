# Shubra Jewels API
PORT=4200
HOST=0.0.0.0
NODE_ENV=development

# MongoDB Atlas connection string (must include the `shubra` database name)
MONGODB_URI=mongodb+srv://user:pass@cluster/shubra?retryWrites=true&w=majority

# Auth
JWT_SECRET=change_me
JWT_EXPIRES_IN=30d

# Seed admin (used only by `npm run seed`)
ADMIN_EMAIL=admin@shubrajewels.in
ADMIN_PASSWORD=change_me

# Public base URL for absolute media links (optional)
PUBLIC_URL=

# Google sign-in (OAuth client ID)
GOOGLE_CLIENT_ID=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook signing secret (Razorpay Dashboard → Settings → Webhooks). Enables the
# server-to-server backstop that saves the order even if the browser closes.
RAZORPAY_WEBHOOK_SECRET=

# Production CORS allow-list (comma-separated). Leave blank in dev.
CORS_ORIGIN=https://shubrajewels.shop,https://www.shubrajewels.shop

# Brevo (Sendinblue) SMTP — order confirmation emails
# Get these from Brevo dashboard → SMTP & API → SMTP
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=              # your Brevo login email
BREVO_SMTP_PASS=              # your Brevo SMTP key (not account password)
EMAIL_FROM=noreply@shubrajewels.shop
EMAIL_FROM_NAME=Shubra Jewels
